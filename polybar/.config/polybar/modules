[module/bspwm]
; https://github.com/polybar/polybar/wiki/Module:-bspwm
type = internal/bspwm

pin-workspaces = true

enable-clicl = true

format = <label-state>

label-focused = 
label-focused-foreground = ${colors.green}

label-occupied = 
label-occupied-foreground = ${colors.green}

label-empty = 
label-empty-foreground = ${colors.dark-green}

label-separator-padding = 2

[module/date]
; https://github.com/polybar/polybar/wiki/Module:-date
type = internal/date

label-foreground = ${colors.foreground}

format = <label>
label = %date% | %time%

interval = 1.0

date = %m-%d%
date-alt = %a, %Y %b %d

time = %I:%M %p
time-alt = %H:%M:%S

