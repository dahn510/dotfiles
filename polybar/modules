[module/battery]
type = internal/battery

; full-at = 90

battery = BAT0
adapter = AC

; time-format = %H:%M

label-full-font = 3
label-full =  ⠿ %percentage%%
format-full-background = ${colors.red}
format-full-padding = 1

format-charging = <ramp-capacity> <animation-charging> <label-charging>
format-charging-background = ${colors.red}
format-charging-padding = 1

format-discharging = <ramp-capacity> <animation-discharging> <label-discharging>
format-discharging-background = ${colors.red}
format-discharging-padding = 1

label-charging = %percentage%%

label-discharging = %percentage%%

ramp-capacity-0 = 
ramp-capacity-1 = 
ramp-capacity-2 = 
ramp-capacity-3 = 
ramp-capacity-4 = 
ramp-capacity-5 = 
ramp-capacity-6 = 
ramp-capacity-7 = 
ramp-capacity-8 = 
ramp-capacity-9 = 

animation-charging-font = 3
animation-charging-0 = ⠾
animation-charging-1 = ⠷
animation-charging-2 = ⠯
animation-charging-3 = ⠟
animation-charging-4 = ⠻
animation-charging-5 = ⠽

animation-charging-framerate = 500

animation-discharging-font = 3
animation-discharging-5 = ⠾
animation-discharging-4 = ⠷
animation-discharging-3 = ⠯
animation-discharging-2 = ⠟
animation-discharging-1 = ⠻
animation-discharging-0 = ⠽

animation-discharging-framerate = 500

[module/bspwm]
type = internal/bspwm

format-padding = 1

pin-workspaces = true

enable-click = true

label-monitor = %name%

label-focused = " %name% "
label-focused-foreground = ${colors.white}
label-focused-background = ${colors.black}
label-focused-underline = ${colors.red}

label-occupied = " %name% "
label-occupied-underline = ${colors.gray}

label-urgent = " %name% "
label-urgent-foreground = ${colors.red}
label-urgent-background = ${colors.black}

label-empty = " %name% "
label-empty-foreground = ${colors.white}

label-separator = "|" 
label-separatpr-padding = 0

[module/date]
type = internal/date

interval = 1.0

; See "https://en.cppreference.com/w/cpp/io/manip/put_time" for details on how to format the date string
date = %d-%m%

time = %I:%M

date-alt = %A, %d %B %Y
time-alt = %I:%M:%S

format = <label>
format-background = ${colors.red}
format-padding = 1

label = %time% %date%


[module/network]
type = internal/network

interface = wlp2s0

interval = 3

format-connected-background = ${colors.red}
format-disconnected-background = ${colors.red}

format-connected = 直:<ramp-signal>
format-connected-padding = 1

format-disconnected = 睊:<label-disconnected>
format-disconnected-padding = 1

ramp-signal-0 = ⣀
ramp-signal-1 = ⣤
ramp-signal-2 = ⣶
ramp-signal-3 = ⣿

animation-disconnected-0 = ⡇
animation-disconnected-1 = ⢸

animation-disconnected-framerate = 500

[module/pulseaudio]
type = internal/pulseaudio

sink = alsa_output.pci-0000_12_00.3.analog-stereo

use-ui-max = true

interval = 5

format-volume = 蓼 <label-volume>
format-volume-padding = 1
format-volume-background = ${colors.red}
label-volume = %percentage%%

format-muted = <label-muted>
format-muted-background = ${colors.red}
format-muted-padding = 1
label-muted = 遼 muted

click-right = pavucontrol
